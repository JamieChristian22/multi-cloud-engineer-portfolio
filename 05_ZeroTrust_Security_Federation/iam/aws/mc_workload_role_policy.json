{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAnalyticsBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::mc-analytics-lake-2026",
        "arn:aws:s3:::mc-analytics-lake-2026/*"
      ]
    },
    {
      "Sid": "WriteMetricsToCloudWatch",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*"
    }
  ]
}