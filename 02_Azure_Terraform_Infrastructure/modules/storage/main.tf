resource "azurerm_storage_account" "this" { name=var.storage_account_name, resource_group_name=var.resource_group_name, location=var.location, account_tier="Standard", account_replication_type="LRS", access_tier="Hot", min_tls_version="TLS1_2", allow_nested_items_to_be_public=false, tags=var.tags }
resource "azurerm_storage_container" "project_files" { name=var.blob_container_name, storage_account_name=azurerm_storage_account.this.name, container_access_type="private" }
resource "azurerm_storage_container" "tfstate" { name=var.tfstate_container, storage_account_name=azurerm_storage_account.this.name, container_access_type="private" }
